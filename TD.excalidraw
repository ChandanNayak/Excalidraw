    {
      "type": "text",
      "id": "jlUFG9KRorji7uWCvU3y",
      "x": 84,
      "y": 7066,
      "width": 510,
      "height": 126.0,
      "text": "Labels come from the rules engine itself:\n  label = rule_weight_score \u2265 0.8\n\nModel learns to generalise the rules' intent\nbeyond their hard thresholds. No analyst\ntime needed to get started.",
      "fontSize": 15,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Labels come from the rules engine itself:\n  label = rule_weight_score \u2265 0.8\n\nModel learns to generalise the rules' intent\nbeyond their hard thresholds. No analyst\ntime needed to get started.",
